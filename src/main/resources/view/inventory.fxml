<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.InventoryController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
        <VBox spacing="16"
              fx:id="root"
              style="
                -fx-padding: 20;
                -fx-background-color: #f4f4f4;
                -fx-border-color: transparent;
              ">

            <children>
                <!-- Filter Buttons -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="allItemsButton"
                                text="All items"
                                onAction="#onFilterAllItems"
                                style="-fx-background-color:#1e40af; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />
                        <Button fx:id="lowStockButton"
                                text="Low stock"
                                onAction="#onFilterLowStock"
                                style="-fx-background-color:#9ecaff; -fx-text-fill:#1d1d1d; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />
                        <Button fx:id="criticalButton"
                                text="Critical"
                                onAction="#onFilterCritical"
                                style="-fx-background-color:#9ecaff; -fx-text-fill:#1d1d1d; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="Import"
                                minWidth="100"
                                onAction="#onImportInventory"
                                maxWidth="Infinity"
                                styleClass="inv-action-btn"/>

                        <Button text="Export"
                                minWidth="100"
                                onAction="#onExportInventory"
                                maxWidth="Infinity"
                                styleClass="inv-action-btn"/>
                    </children>
                </HBox>

                <!-- Search Bar -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="searchField"
                                   promptText="Search item..."
                                   onAction="#onApplyFilter"
                                   prefWidth="300"
                                   style="-fx-background-color:#ffffff; -fx-background-radius:24; -fx-border-radius:24; -fx-padding:10 16 10 16; -fx-font-size:14; -fx-text-fill:#1d1d1d; -fx-prompt-text-fill:#7a7a7a;" />
                        <Button text="Filter"
                                onAction="#onApplyFilter"
                                style="-fx-background-color:#ffffff; -fx-text-fill:#1d1d1d; -fx-background-radius:24; -fx-border-color:#1e88e5; -fx-border-radius:24; -fx-padding:10 20 10 20; -fx-cursor:hand;" />
                    
                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="editButton"
                                text="Edit"
                                minWidth="100"
                                onAction="#toggleEditMode"
                                maxWidth="Infinity"
                                styleClass="inv-edit-btn"/>
                    </children>
                </HBox>

                <!-- Header Row -->
                <GridPane hgap="0"
                          style="-fx-background-color:white; -fx-background-radius:16; -fx-border-radius:16; -fx-border-color:#1e88e5; -fx-border-width:2; -fx-padding:12 16 12 16;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="18" />
                        <ColumnConstraints percentWidth="22" />
                        <ColumnConstraints percentWidth="14" />
                        <ColumnConstraints percentWidth="18" />
                        <ColumnConstraints percentWidth="18" />
                    </columnConstraints>
                    <children>
                        <Label fx:id="itemIdHeaderLabel"
                               text="Item ID"
                               onMouseClicked="#onSortByItemId"
                               GridPane.columnIndex="0"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                        <Label fx:id="nameHeaderLabel"
                               text="Name"
                               onMouseClicked="#onSortByName"
                               GridPane.columnIndex="1"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                        <Label fx:id="quantityHeaderLabel"
                               text="Quantity"
                               onMouseClicked="#onSortByQuantity"
                               GridPane.columnIndex="2"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                        <Label fx:id="minimalQuantityHeaderLabel"
                               text="Minimal quantity"
                               onMouseClicked="#onSortByMinimalQuantity"
                               GridPane.columnIndex="3"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                        <Label fx:id="statusHeaderLabel"
                               text="Status"
                               onMouseClicked="#onSortByStatus"
                               GridPane.columnIndex="4"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                    </children>
                </GridPane>

                <!-- Items Container -->
                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;">
                    
                    <VBox fx:id="itemsContainer" spacing="10" />

                </ScrollPane>

                <Region VBox.vgrow="ALWAYS" />
            </children>

            <padding>
                <Insets top="0" right="0" bottom="0" left="0" />
            </padding>
        </VBox>
    </center>

</BorderPane>
