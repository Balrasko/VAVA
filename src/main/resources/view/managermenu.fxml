<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.MenuController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="page-scroll">
            <content>
                <VBox fillWidth="true"
                      maxWidth="Infinity"
                      maxHeight="Infinity">
                    <children>
                        <HBox spacing="20"
                              alignment="TOP_LEFT"
                              maxWidth="Infinity"
                              fillHeight="true"
                              VBox.vgrow="ALWAYS"
                              styleClass="page-content">
                            <children>

                                <VBox fx:id="menuListPanel"
                                      spacing="0"
                                      minWidth="360"
                                      maxHeight="Infinity"
                                      HBox.hgrow="ALWAYS"
                                      styleClass="menu-outer-panel">
                                    <children>

                                        <ScrollPane fitToHeight="true"
                                                    fitToWidth="true"
                                                    hbarPolicy="AS_NEEDED"
                                                    vbarPolicy="NEVER"
                                                    pannable="true"
                                                    styleClass="menu-tabs-scroll">
                                            <content>
                                                <HBox fx:id="categoryTabsContainer"
                                                      spacing="0"
                                                      styleClass="menu-tabs-bar" />
                                            </content>
                                        </ScrollPane>

                                        <VBox spacing="18"
                                              maxHeight="Infinity"
                                              VBox.vgrow="ALWAYS"
                                              styleClass="menu-inner-panel">
                                            <children>

                                                <VBox fx:id="categorySectionsContainer"
                                                      spacing="18"
                                                      maxHeight="Infinity"
                                                      VBox.vgrow="ALWAYS" />

                                                <Region VBox.vgrow="ALWAYS" />

                                                <HBox alignment="CENTER_RIGHT"
                                                      spacing="12">
                                                    <children>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="editCategoryButton"
                                                                text="Edit category"
                                                                onAction="#onEditCategory"
                                                                wrapText="true"
                                                                styleClass="secondary-action-button" />
                                                        <Button fx:id="deleteCategoryActionButton"
                                                                text="Delete category"
                                                                onAction="#onDeleteCurrentCategory"
                                                                wrapText="true"
                                                                styleClass="secondary-action-button" />
                                                        <Button fx:id="addMenuButton"
                                                                text="Add menu"
                                                                onAction="#onAddMenu"
                                                                wrapText="true"
                                                                styleClass="green-action-button" />
                                                    </children>
                                                    <padding>
                                                        <Insets top="0" right="0" bottom="4" left="0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <ScrollPane fx:id="menuFormPanel"
                                    fitToWidth="true"
                                    fitToHeight="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="NEVER"
                                    pannable="false"
                                    prefWidth="360"
                                    minWidth="320"
                                    maxWidth="390"
                                    maxHeight="Infinity"
                                    visible="false"
                                    managed="false"
                                    styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button text="✕"
                                                        onAction="#onCloseForm"
                                                        styleClass="form-close-button" />
                                            </children>
                                        </HBox>

                                        <Label fx:id="menuFormTitle"
                                               text="Add menu"
                                               wrapText="true"
                                               styleClass="menu-category-title" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Name" styleClass="form-label" />
                                                <TextField fx:id="nameField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Description" styleClass="form-label" />
                                                <TextField fx:id="descriptionField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Ingredients" styleClass="form-label" />
                                                <TextField fx:id="ingredientsField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Category" styleClass="form-label" />
                                                <ComboBox fx:id="categoryField"
                                                          maxWidth="Infinity"
                                                          styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="20">
                                            <children>
                                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Price" styleClass="form-label" />
                                                        <TextField fx:id="priceField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Discount" styleClass="form-label" />
                                                        <TextField fx:id="discountField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <Region VBox.vgrow="ALWAYS" />

                                        <HBox alignment="CENTER_RIGHT" spacing="12">
                                            <children>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button text="Cancel"
                                                        onAction="#onCloseForm"
                                                        wrapText="true"
                                                        styleClass="secondary-action-button" />
                                                <Button fx:id="deleteMenuButton"
                                                        text="Delete"
                                                        visible="false"
                                                        managed="false"
                                                        wrapText="true"
                                                        onAction="#onDeleteMenu"
                                                        styleClass="secondary-action-button" />
                                                <Button fx:id="submitMenuButton"
                                                        text="Add menu"
                                                        onAction="#onSubmitMenu"
                                                        wrapText="true"
                                                        styleClass="green-action-button" />
                                            </children>
                                        </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

                                <ScrollPane fx:id="categoryFormPanel"
                                    fitToWidth="true"
                                    fitToHeight="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="NEVER"
                                    pannable="false"
                                    prefWidth="360"
                                    minWidth="320"
                                    maxWidth="390"
                                    maxHeight="Infinity"
                                    visible="false"
                                    managed="false"
                                    styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button text="✕"
                                                        onAction="#onCloseCategoryForm"
                                                        styleClass="form-close-button" />
                                            </children>
                                        </HBox>

                                        <Label fx:id="categoryFormTitle"
                                               text="Add category"
                                               wrapText="true"
                                               styleClass="menu-category-title" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="Category name" styleClass="form-label" />
                                                <TextField fx:id="categoryNameField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS" />

                                        <HBox alignment="CENTER_RIGHT" spacing="12">
                                            <children>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button text="Cancel"
                                                        onAction="#onCloseCategoryForm"
                                                        wrapText="true"
                                                        styleClass="secondary-action-button" />
                                                <Button fx:id="deleteCategoryButton"
                                                        text="Delete"
                                                        visible="false"
                                                        managed="false"
                                                        wrapText="true"
                                                        onAction="#onDeleteCategory"
                                                        styleClass="secondary-action-button" />
                                                <Button fx:id="submitCategoryButton"
                                                        text="Add category"
                                                        onAction="#onSubmitCategory"
                                                        wrapText="true"
                                                        styleClass="green-action-button" />
                                            </children>
                                        </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
