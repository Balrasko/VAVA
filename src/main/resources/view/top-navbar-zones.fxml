<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="dev.vavateam1.controller.TopNavbarZonesController"
    prefHeight="56.0"
    minHeight="56.0"
    maxHeight="56.0"
      styleClass="top-nav">

    <children>

        <StackPane>
            <children>
                <Button fx:id="restaurantButton" text="Restaurant" styleClass="nav-tab" onAction="#onRestaurant" />
                <Button fx:id="restaurantDeleteButton"
                    text="X"
                        onAction="#onDeleteRestaurant"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                    style="-fx-background-color: #d62828; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-font-weight: 900; -fx-font-family: 'Arial'; -fx-cursor: hand; -fx-padding: 0 0 1 0; -fx-background-radius: 999; -fx-border-radius: 999; -fx-min-width: 20; -fx-min-height: 20; -fx-max-width: 20; -fx-max-height: 20; -fx-alignment: center; -fx-border-color: transparent; -fx-border-color: #7f1d1d; -fx-border-width: 1;">
                    <StackPane.margin>
                        <Insets top="3" right="6"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <StackPane>
            <children>
                <Button fx:id="teraceButton" text="Terace" styleClass="nav-tab" onAction="#onTerace" />
                <Button fx:id="teraceDeleteButton"
                    text="X"
                        onAction="#onDeleteTerace"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                    style="-fx-background-color: #d62828; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-font-weight: 900; -fx-font-family: 'Arial'; -fx-cursor: hand; -fx-padding: 0 0 1 0; -fx-background-radius: 999; -fx-border-radius: 999; -fx-min-width: 20; -fx-min-height: 20; -fx-max-width: 20; -fx-max-height: 20; -fx-alignment: center; -fx-border-color: transparent; -fx-border-color: #7f1d1d; -fx-border-width: 1;">
                    <StackPane.margin>
                        <Insets top="3" right="6"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <StackPane>
            <children>
                <Button fx:id="barButton" text="Bar" styleClass="nav-tab" onAction="#onBar" />
                <Button fx:id="barDeleteButton"
                    text="X"
                        onAction="#onDeleteBar"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                    style="-fx-background-color: #d62828; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-font-weight: 900; -fx-font-family: 'Arial'; -fx-cursor: hand; -fx-padding: 0 0 1 0; -fx-background-radius: 999; -fx-border-radius: 999; -fx-min-width: 20; -fx-min-height: 20; -fx-max-width: 20; -fx-max-height: 20; -fx-alignment: center; -fx-border-color: transparent; -fx-border-color: #7f1d1d; -fx-border-width: 1;">
                    <StackPane.margin>
                        <Insets top="3" right="6"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <Region HBox.hgrow="ALWAYS" />
    </children>

    <padding>
        <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
    </padding>
</HBox>
