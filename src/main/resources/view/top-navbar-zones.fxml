<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="dev.vavateam1.controller.TopNavbarZonesController"
    prefHeight="56.0"
    minHeight="56.0"
    maxHeight="56.0"
      styleClass="top-nav">

    <children>

        <StackPane>
            <children>
                <Button fx:id="restaurantButton" text="Restaurant" styleClass="nav-tab" onAction="#onRestaurant" />
                <Button fx:id="restaurantDeleteButton"
                        text="✕"
                        onAction="#onDeleteRestaurant"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                        style="-fx-background-color: transparent; -fx-text-fill: #d62828; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0; -fx-min-width: 16; -fx-min-height: 16;">
                    <StackPane.margin>
                        <Insets top="6" right="8"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <StackPane>
            <children>
                <Button fx:id="teraceButton" text="Terace" styleClass="nav-tab" onAction="#onTerace" />
                <Button fx:id="teraceDeleteButton"
                        text="✕"
                        onAction="#onDeleteTerace"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                        style="-fx-background-color: transparent; -fx-text-fill: #d62828; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0; -fx-min-width: 16; -fx-min-height: 16;">
                    <StackPane.margin>
                        <Insets top="6" right="8"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <StackPane>
            <children>
                <Button fx:id="barButton" text="Bar" styleClass="nav-tab" onAction="#onBar" />
                <Button fx:id="barDeleteButton"
                        text="✕"
                        onAction="#onDeleteBar"
                        visible="false"
                        managed="false"
                        StackPane.alignment="TOP_RIGHT"
                        style="-fx-background-color: transparent; -fx-text-fill: #d62828; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0; -fx-min-width: 16; -fx-min-height: 16;">
                    <StackPane.margin>
                        <Insets top="6" right="8"/>
                    </StackPane.margin>
                </Button>
            </children>
        </StackPane>

        <Region HBox.hgrow="ALWAYS" />
    </children>

    <padding>
        <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
    </padding>
</HBox>
