<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.DashboardController">

    <!-- LEFT SIDEBAR -->
    <left>
    <VBox fx:id="sidebar"
      spacing="10"
      prefWidth="208"
      styleClass="sidebar"
      style="-fx-padding: 20;"
      fillWidth="true">

    <!-- MENU ITEMS -->
    <HBox styleClass="sidebar-item"
          onMouseClicked="#showTableView">
        <Label text="Tables" styleClass="sidebar-label"/>
    </HBox>

    <HBox styleClass="sidebar-item"
          onMouseClicked="#showClosing">
        <Label text="Closing" styleClass="sidebar-label"/>
    </HBox>

    <HBox styleClass="sidebar-item"
          onMouseClicked="#showHistory">
        <Label text="History" styleClass="sidebar-label"/>
    </HBox>

        <HBox fx:id="managerPanelItem"
          styleClass="sidebar-item"
          onMouseClicked="#showManager">
        <Label text="Manager panel" styleClass="sidebar-label"/>
    </HBox>

    <!-- SPACER -->
    <VBox VBox.vgrow="ALWAYS"/>

    <!-- LOGOUT -->
    <Button text="Logout"
            onAction="#logout"
            maxWidth="1.7976931348623157E308"
            styleClass="sidebar-logout-button"/>

    <!-- PROFILE -->
    <VBox alignment="CENTER" spacing="8">
        <Label text="Logged in as"
               style="-fx-text-fill: white; -fx-font-size: 11px;"/>
        <Label fx:id="loggedInRoleLabel"
               text="Waiter"
               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

</VBox>
</left>

    <!-- TOP BAR -->
    <top>
      <VBox fx:id="topSection">
        <children>
          <HBox spacing="15"
                alignment="CENTER_LEFT"
                prefHeight="56.0"
                minHeight="56.0"
                maxHeight="56.0"
                styleClass="dashboard-top-bar">
            <Label text="☰"
                   onMouseClicked="#toggleSidebar"
                   styleClass="sidebar-toggle"/>
            <HBox fx:id="topNavbarContainer"
                  HBox.hgrow="ALWAYS"
                  prefHeight="56.0"
                  minHeight="56.0"
                  maxHeight="56.0"
                  alignment="CENTER_LEFT"/>
          </HBox>
        </children>
      </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="contentArea"
           alignment="CENTER"
           style="-fx-background-color: #f4f4f4;">
        </StackPane>
    </center>

</BorderPane>
