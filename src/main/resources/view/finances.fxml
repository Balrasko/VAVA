<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.FinancesController"
            maxWidth="Infinity"
            style="-fx-background-color:#f4f4f4;">

    <center>
        <HBox spacing="16"
              maxWidth="Infinity"
              style="-fx-padding:20; -fx-background-color:#f4f4f4;">
            <children>
                <VBox spacing="14"
                      prefWidth="560"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#d9d9d9; -fx-background-radius:24; -fx-padding:20;">

                    <children>
                        <GridPane hgap="0"
                                  style="-fx-background-color:#f4f4f4; -fx-background-radius:24; -fx-border-radius:24; -fx-border-color:#1e88e5; -fx-border-width:2; -fx-padding:12 16 12 16;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            <children>
                                <Label text="Item ID"
                                       GridPane.columnIndex="0"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label text="Name"
                                       GridPane.columnIndex="1"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label text="Sold pieces"
                                       GridPane.columnIndex="2"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label text="Price per piece"
                                       GridPane.columnIndex="3"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                            </children>
                        </GridPane>

                        <GridPane hgap="0"
                                  style="-fx-background-color:#f4f4f4; -fx-background-radius:16; -fx-padding:10 16 10 16;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            <children>
                                <Label fx:id="itemIdLabel"
                                       text="22"
                                       GridPane.columnIndex="0"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label fx:id="itemNameLabel"
                                       text="Kuraci rezen"
                                       GridPane.columnIndex="1"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label fx:id="soldPiecesLabel"
                                       text="12"
                                       GridPane.columnIndex="2"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                                <Label fx:id="pricePerPieceLabel"
                                       text="12.50"
                                       GridPane.columnIndex="3"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font-size:14; -fx-text-fill:#1d1d1d;" />
                            </children>
                        </GridPane>

                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <VBox spacing="18"
                      prefWidth="560"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#d9d9d9; -fx-background-radius:24; -fx-padding:20;">

                    <children>
                        <HBox spacing="22">
                            <children>
                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label text="Daily sales" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label fx:id="dailySalesLabel" text="2453.65" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="22">
                            <children>
                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label text="Sold items" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label fx:id="soldItemsTotalLabel" text="45" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button text="Export finance report"
                                        onAction="#onExportFinanceReport"
                                        style="-fx-background-color:#57c84d; -fx-text-fill:#1d1d1d; -fx-background-radius:24; -fx-padding:12 24 12 24; -fx-cursor:hand;" />
                            </children>
                            <padding>
                                <Insets top="0" right="0" bottom="4" left="0" />
                            </padding>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

</BorderPane>

