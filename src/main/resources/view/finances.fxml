<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.FinancesController"
            maxWidth="Infinity"
            style="-fx-background-color:#f4f4f4;">

    <center>
        <HBox spacing="16"
              maxWidth="Infinity"
              style="-fx-padding:20; -fx-background-color:#f4f4f4;">
            <children>
                <VBox spacing="14"
                      prefWidth="560"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#d9d9d9; -fx-background-radius:24; -fx-padding:20;">

                    <children>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <TextField fx:id="searchField"
                                           promptText="Search item..."
                                           onAction="#onApplyFilter"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color:#f4f4f4; -fx-background-radius:24; -fx-border-radius:24; -fx-padding:10 16 10 16; -fx-font-size:14; -fx-text-fill:#1d1d1d; -fx-prompt-text-fill:#7a7a7a;" />
                                <Button text="Filter"
                                        onAction="#onApplyFilter"
                                        style="-fx-background-color:#f4f4f4; -fx-text-fill:#1d1d1d; -fx-background-radius:24; -fx-border-color:#1e88e5; -fx-border-radius:24; -fx-padding:10 20 10 20; -fx-cursor:hand;" />
                            </children>
                        </HBox>

                        <GridPane hgap="0"
                                  style="-fx-background-color:#f4f4f4; -fx-background-radius:24; -fx-border-radius:24; -fx-border-color:#1e88e5; -fx-border-width:2; -fx-padding:12 16 12 16;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            <children>
                                <Label fx:id="itemIdHeaderLabel"
                                       text="Item ID"
                                       onMouseClicked="#onSortByItemId"
                                       GridPane.columnIndex="0"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                                <Label fx:id="itemNameHeaderLabel"
                                       text="Name"
                                       onMouseClicked="#onSortByName"
                                       GridPane.columnIndex="1"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                                <Label fx:id="soldPiecesHeaderLabel"
                                       text="Sold pieces"
                                       onMouseClicked="#onSortBySoldPieces"
                                       GridPane.columnIndex="2"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                                <Label fx:id="pricePerPieceHeaderLabel"
                                       text="Price per piece"
                                       onMouseClicked="#onSortByPricePerPiece"
                                       GridPane.columnIndex="3"
                                       GridPane.halignment="CENTER"
                                       style="-fx-font: bold 14px system; -fx-text-fill:#1d1d1d; -fx-cursor:hand;" />
                            </children>
                        </GridPane>

                        <VBox fx:id="itemsContainer" spacing="10" />

                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <VBox spacing="18"
                      prefWidth="560"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#d9d9d9; -fx-background-radius:24; -fx-padding:20;">

                    <children>
                        <HBox spacing="22">
                            <children>
                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label text="Daily sales" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label fx:id="dailySalesLabel" text="2453.65" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="22">
                            <children>
                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label text="Sold items" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER"
                                      prefWidth="245"
                                      prefHeight="98"
                                      style="-fx-background-color:#f4f4f4; -fx-background-radius:24;">
                                    <children>
                                        <Label fx:id="soldItemsTotalLabel" text="45" style="-fx-font-size:30; -fx-text-fill:#1d1d1d;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button text="Export finance report"
                                        onAction="#onExportFinanceReport"
                                        style="-fx-background-color:#57c84d; -fx-text-fill:#1d1d1d; -fx-background-radius:24; -fx-padding:12 24 12 24; -fx-cursor:hand;" />
                            </children>
                            <padding>
                                <Insets top="0" right="0" bottom="4" left="0" />
                            </padding>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

</BorderPane>
