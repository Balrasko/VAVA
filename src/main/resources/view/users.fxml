<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.UsersController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
        <HBox spacing="20"
              alignment="TOP_LEFT"
              maxWidth="Infinity"
              fillHeight="true"
              styleClass="page-content">
            <children>

                <VBox spacing="0"
                      minWidth="360"
                      maxHeight="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="menu-outer-panel">
                    <children>
                        <VBox spacing="18"
                              maxHeight="Infinity"
                              VBox.vgrow="ALWAYS"
                              styleClass="menu-inner-panel">
                            <children>
                                <ScrollPane fitToWidth="true"
                                            hbarPolicy="NEVER"
                                            vbarPolicy="AS_NEEDED"
                                            VBox.vgrow="ALWAYS"
                                            styleClass="page-scroll">
                                    <content>
                                        <VBox fx:id="usersList" spacing="18" />
                                    </content>
                                </ScrollPane>
                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Create user"
                                                onAction="#onCreateUser"
                                                styleClass="green-action-button" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                                <ScrollPane fx:id="userFormPanel"
                                            fitToWidth="true"
                                            fitToHeight="true"
                                            hbarPolicy="NEVER"
                                            vbarPolicy="NEVER"
                                            pannable="false"
                                            prefWidth="360"
                                            minWidth="320"
                                            maxWidth="390"
                                            maxHeight="Infinity"
                                            visible="false"
                                            managed="false"
                                            styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                            <HBox alignment="CENTER_RIGHT">
                                                <children>
                                                    <Button text="✕"
                                                            onAction="#onCloseForm"
                                                            styleClass="form-close-button" />
                                                </children>
                                            </HBox>

                                            <Label fx:id="formTitle"
                                                   text="Create user"
                                                   wrapText="true"
                                                   styleClass="menu-category-title" />

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="Name" styleClass="form-label" />
                                                    <TextField fx:id="nameField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="Surname" styleClass="form-label" />
                                                    <TextField fx:id="surnameField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="Email" styleClass="form-label" />
                                                    <TextField fx:id="emailField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="Password" styleClass="form-label" />
                                                    <PasswordField fx:id="passwordField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="Repeat password" styleClass="form-label" />
                                                    <PasswordField fx:id="repeatPasswordField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="10">
                                                <children>
                                                    <Label text="Role" styleClass="form-label" />
                                                    <RadioButton fx:id="waiterRadio" text="Waiter"
                                                                 toggleGroup="$roleToggleGroup" />
                                                    <RadioButton fx:id="chefRadio" text="Chef"
                                                                 toggleGroup="$roleToggleGroup" />
                                                    <RadioButton fx:id="managerRadio" text="Manager"
                                                                 toggleGroup="$roleToggleGroup" />
                                                </children>

                                                <fx:define>
                                                    <ToggleGroup fx:id="roleToggleGroup" />
                                                </fx:define>
                                            </VBox>

                                            <Region VBox.vgrow="ALWAYS" />

                                            <HBox alignment="CENTER_RIGHT" spacing="12">
                                                <children>
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button text="Cancel"
                                                            onAction="#onCloseForm"
                                                            wrapText="true"
                                                            styleClass="secondary-action-button" />
                                                    <Button fx:id="submitUserButton"
                                                            text="Create user"
                                                            onAction="#onSubmitUser"
                                                            wrapText="true"
                                                            styleClass="green-action-button" />
                                                </children>
                                            </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

            </children>
        </HBox>
    </center>
</BorderPane>
