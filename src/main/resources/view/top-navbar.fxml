<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.vavateam1.controller.TopNavbarController"
    prefHeight="56.0"
    minHeight="56.0"
    maxHeight="56.0"
      styleClass="top-nav">

    <children>

        <Button fx:id="usersButton" text="Users" styleClass="nav-tab" onAction="#onUsers" />
        <Button fx:id="menuButton" text="Menu" styleClass="nav-tab" onAction="#onMenu" />
        <Button fx:id="financesButton" text="Finances" styleClass="nav-tab" onAction="#onFinances" />
        <Button fx:id="inventoryButton" text="Inventory" styleClass="nav-tab" onAction="#onInventory" />
        <Button fx:id="tableLayoutButton" text="Table Layout" styleClass="nav-tab" onAction="#onTableLayout" />

        <Region HBox.hgrow="ALWAYS" />
    </children>

    <padding>
        <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
    </padding>
</HBox>
